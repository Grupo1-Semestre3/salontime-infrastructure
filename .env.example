# ============================================
# SalonTime AWS Infrastructure Configuration
# ============================================
# Copy this file to .env and fill in your values
# Use ./configure.sh for interactive setup

# ============================================
# AWS Configuration
# ============================================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# ============================================
# Project Configuration
# ============================================
PROJECT_NAME=salontime
ENVIRONMENT=production  # dev, staging, production
PROJECT_TAG=SalonTime

# ============================================
# Network Configuration
# ============================================
VPC_CIDR=10.0.0.0/16
PUBLIC_SUBNET_CIDR=10.0.1.0/24
PRIVATE_SUBNET1_CIDR=10.0.2.0/24
PRIVATE_SUBNET2_CIDR=10.0.3.0/24

# Availability Zones (2 required for Multi-AZ RDS)
AZ1=us-east-1a
AZ2=us-east-1b

# ============================================
# EC2 Configuration
# ============================================
# Instance types (t3.medium recommended for production)
FRONTEND_INSTANCE_TYPE=t3.medium
BACKEND_INSTANCE_TYPE=t3.medium
BOTPRESS_INSTANCE_TYPE=t3.medium

# SSH Key Pair (must exist in AWS region)
KEY_PAIR_NAME=my-keypair
KEY_FILE_PATH=/path/to/my-keypair.pem

# AMI (leave empty to auto-detect latest Amazon Linux 2)
AMI_ID=

# ============================================
# RDS Configuration
# ============================================
# Database
DB_INSTANCE_CLASS=db.t3.medium
DB_ALLOCATED_STORAGE=20  # GB
DB_ENGINE_VERSION=8.0
DB_NAME=salontime_db
DB_USERNAME=admin
DB_PASSWORD=SecurePassword123!  # CHANGE THIS!
DB_PORT=3306

# High Availability
DB_MULTI_AZ=true  # true for production, false for dev
DB_BACKUP_RETENTION=14  # days (7-35 for production)

# ============================================
# Application Configuration
# ============================================
# Frontend (React + Vite)
FRONTEND_PORT=3000
FRONTEND_REPO=https://github.com/Grupo1-Semestre3/salontime-front-end-react
FRONTEND_BRANCH=main

# Backend (Spring Boot + Kotlin)
BACKEND_PORT=8080
BACKEND_REPO=https://github.com/Grupo1-Semestre3/salontime-app-kotlin
BACKEND_BRANCH=main

# BotPress Chatbot
BOTPRESS_PORT=8081
BOTPRESS_REPO=https://github.com/Grupo1-Semestre3/salontime-bot-atendimento
BOTPRESS_BRANCH=main

# Database Scripts
DB_REPO=https://github.com/Grupo1-Semestre3/salontime-banco-dados
DB_BRANCH=main

# ============================================
# Load Balancer Configuration
# ============================================
ALB_NAME=salontime-alb
HEALTH_CHECK_PATH=/
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5
HEALTHY_THRESHOLD=2
UNHEALTHY_THRESHOLD=3

# ============================================
# WAF Configuration
# ============================================
ENABLE_WAF=true
WAF_RATE_LIMIT=2000  # requests per 5 minutes per IP

# ============================================
# Security Configuration
# ============================================
# Allowed IP for SSH access (use 0.0.0.0/0 for any, or your IP for security)
SSH_ALLOWED_CIDR=0.0.0.0/0

# Allowed IP for RDS access (usually private subnets only)
DB_ALLOWED_CIDR=10.0.0.0/16

# ============================================
# Monitoring & Logging
# ============================================
ENABLE_CLOUDWATCH=true
LOG_RETENTION_DAYS=7

# ============================================
# Tags (for resource organization)
# ============================================
TAGS_OWNER=DevOps Team
TAGS_COST_CENTER=Engineering
TAGS_PROJECT=SalonTime

# ============================================
# Cost Optimization
# ============================================
# Auto shutdown for dev environments (optional)
AUTO_SHUTDOWN_ENABLED=false
AUTO_SHUTDOWN_TIME=18:00

# ============================================
# Backup Configuration
# ============================================
ENABLE_BACKUPS=true
BACKUP_RETENTION_DAYS=7

# ============================================
# Notification (optional)
# ============================================
NOTIFICATION_EMAIL=devops@example.com
SNS_TOPIC_ARN=

# ============================================
# Advanced Configuration
# ============================================
# Docker Registry (leave empty to use Docker Hub)
DOCKER_REGISTRY=

# Custom Domain (optional)
CUSTOM_DOMAIN=
ROUTE53_HOSTED_ZONE_ID=

# SSL Certificate ARN (for HTTPS)
SSL_CERTIFICATE_ARN=
